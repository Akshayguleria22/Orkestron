{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Task Throughput (req/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(agent_tasks_total[1m]) * 60",
          "legendFormat": "{{intent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm" },
        "overrides": []
      }
    },
    {
      "title": "Workflow Outcomes",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "successful_outcomes_total",
          "legendFormat": "Successful",
          "refId": "A"
        },
        {
          "expr": "failed_workflows_total",
          "legendFormat": "Failed",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Billing Events",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "billing_events_total",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Agent Execution Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agent_execution_time_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(agent_execution_time_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Plugin Executions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(plugin_executions_total[5m]) * 60",
          "legendFormat": "{{plugin_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m]) * 60",
          "legendFormat": "{{method}} {{endpoint}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm" },
        "overrides": []
      }
    },
    {
      "title": "HTTP Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["orkestron"],
  "templating": { "list": [] },
